FROM python:3.11-slim

WORKDIR /app

# Install Python packages
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy dbt project (needed for test definitions)
COPY dbt_project.yml packages.yml profiles.yml ./
COPY models/sources.yml models/sources.yml

# Run tests ONLY (assumes raw_data table exists)
CMD ["sh", "-c", "dbt deps && dbt test --select source:data_raw"]
